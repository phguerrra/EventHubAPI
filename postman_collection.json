{
  "info": {
    "name": "BackGrupo1 API - Test Collection (tickets updated)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleção atualizada para testar endpoints de tickets (QR/JWT) e endpoints existentes.",
    "_postman_id": "backgrupo1-collection"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminToken", "value": "" },
    { "key": "ticketToken", "value": "" },
    { "key": "eventId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "participantId", "value": "1" }
  ],
  "item": [
    {
      "name": "Admin - Login (get admin JWT)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"adminpass\",\n  \"expirationMinutes\": 120\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
      },
      "response": []
    },
    {
      "name": "Create Ticket (requires admin JWT)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"eventId\": {{eventId}},\n  \"expirationMinutes\": 120\n}"
        },
        "url": { "raw": "{{baseUrl}}/tickets", "host": ["{{baseUrl}}"], "path": ["tickets"] }
      },
      "response": []
    },
    {
      "name": "Validate Ticket (requires admin JWT)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{ticketToken}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/tickets/validar", "host": ["{{baseUrl}}"], "path": ["tickets","validar"] }
      },
      "response": []
    },

    {
      "name": "Register user",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao@example.com\",\n  \"password\": \"senha123\",\n  \"cpf\": \"12345678901\",\n  \"dataNascimento\": \"1990-01-01\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users","register"] }
      }
    },
    {
      "name": "Login user",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"joao@example.com\",\n  \"password\": \"senha123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/users/login", "host": ["{{baseUrl}}"], "path": ["users","login"] }
      }
    },
    {
      "name": "Get current user info",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users","me"] }
      }
    },
    {
      "name": "Create event",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Festa de Teste\",\n  \"description\": \"Evento para testes\",\n  \"date\": \"2026-05-01\",\n  \"time\": \"20:00:00\",\n  \"location\": \"Auditório\",\n  \"maxParticipants\": 100,\n  \"majority18\": false,\n  \"category\": \"show\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] }
      }
    },
    {
      "name": "List events",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] }
      }
    },
    {
      "name": "Get event by id",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["events","{{eventId}}"] }
      }
    }
  ]
}
