# Arquivo de exemplo para variáveis de ambiente
# Copie este arquivo para .env e ajuste conforme necessário

# PostgreSQL
POSTGRES_DB=eventdb
POSTGRES_PASSWORD=secret
POSTGRES_USER=myuser
POSTGRES_PORT=5433

# Spring Boot Application
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/eventdb
SPRING_DATASOURCE_USERNAME=myuser
SPRING_DATASOURCE_PASSWORD=secret
JWT_SECRET=dev-secret-key-dev-secret-key-123456
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SERVER_PORT=8080

